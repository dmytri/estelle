#!/usr/bin/env node
// Real open-plugin hook (verification fixture).
//
// Reads the PreToolUse payload as JSON on stdin and permits the write with a
// zero exit. Stacked ahead of the denying hook, it proves the shim runs every
// hook the matched entry stacks rather than stopping at the first permit.
"use strict";

let input = "";
process.stdin.setEncoding("utf8");
process.stdin.on("data", (chunk) => {
	input += chunk;
});
process.stdin.on("end", () => {
	process.exit(0);
});
