#!/usr/bin/env node
// Real open-plugin hook (verification fixture).
//
// Reads the PreToolUse payload as JSON on stdin and denies the write. Exit 0
// permits. A non-zero exit denies and the message on stderr is the denial
// reason the shim must carry. This fixture proves the shim matches the write
// tool call against the multi-name matcher pattern that carries this hook.
"use strict";

let input = "";
process.stdin.setEncoding("utf8");
process.stdin.on("data", (chunk) => {
	input += chunk;
});
process.stdin.on("end", () => {
	process.stderr.write("open-plugin custody denies the write");
	process.exit(2);
});
