#!/usr/bin/env node
// Real open-plugin PostToolUse hook (verification fixture).
//
// Reads the PostToolUse payload as JSON on stdin and exits non-zero. A
// PostToolUse hook runs after the tool call, so a non-zero exit is not a gate:
// the shim must run it and leave the completed tool call unblocked.
"use strict";

let input = "";
process.stdin.setEncoding("utf8");
process.stdin.on("data", (chunk) => {
	input += chunk;
});
process.stdin.on("end", () => {
	process.stderr.write("post-tool hook failed but does not block");
	process.exit(2);
});
