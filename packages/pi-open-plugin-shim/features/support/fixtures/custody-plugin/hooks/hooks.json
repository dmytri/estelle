{
  "PreToolUse": [
    {
      "matcher": "write|edit",
      "hooks": [{ "type": "command", "command": "hooks/write-custody" }]
    },
    {
      "matcher": "bash",
      "hooks": [{ "type": "command", "command": "hooks/command-custody" }]
    },
    {
      "matcher": "read",
      "hooks": [{ "type": "command", "command": "hooks/read-custody" }]
    }
  ]
}
