{
  "no-dupe-feature-names": "error",
  "no-dupe-scenario-names": ["error", "anywhere"],
  "no-empty-file": "error",
  "no-files-without-scenarios": "error",
  "no-trailing-spaces": "error",
  "new-line-at-eof": ["error", "yes"],
  "no-multiple-empty-lines": "error",
  "indentation": ["error", {
    "Feature": 0,
    "Rule": 2,
    "Background": 2,
    "Scenario": 2,
    "Step": 4,
    "Examples": 4,
    "example": 6
  }]
}
